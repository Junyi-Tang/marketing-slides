  <div class="click-hint">tap → next · swipe?</div>

  <script>
    (function(){
      const slideOrder = ['s1','s2','s3','s4','s5','s6','s7','s75','s8','s9','s10','s12'];
      const storageKey = 'guenther_mobile_idx';
      const revealKey = 'guenther_mobile_rev';
      let idx = 0;
      try {
        const saved = localStorage.getItem(storageKey);
        if (saved) idx = Math.min(slideOrder.length-1, Math.max(0, parseInt(saved,10)));
      } catch(e){}
      const hash = window.location.hash.slice(1);
      if (hash && slideOrder.includes(hash)) idx = slideOrder.indexOf(hash);

      let revealState = {};
      try { revealState = JSON.parse(localStorage.getItem(revealKey) || '{}'); } catch(e){}

      function currentId() { return slideOrder[idx]; }
      function getSlideEl(id=currentId()) { return document.getElementById(id); }

      function getRevealCount(id) { return revealState[id] || 0; }
      function setRevealCount(id, count) { revealState[id] = Math.max(0, count); localStorage.setItem(revealKey, JSON.stringify(revealState)); }

      function applyReveals(slideEl) {
        const reveals = Array.from(slideEl.querySelectorAll('.reveal'));
        const shown = getRevealCount(slideEl.id);
        reveals.forEach((el,i) => el.classList.toggle('show', i < shown));
        updateNav();
      }

      function updateNav() {
        const slideEl = getSlideEl();
        const reveals = slideEl.querySelectorAll('.reveal').length;
        const shown = getRevealCount(slideEl.id);
        const prevBtn = document.querySelectorAll('.nav-btn')[0];
        const nextBtn = document.querySelectorAll('.nav-btn')[1];
        if (prevBtn) prevBtn.disabled = (idx === 0 && shown === 0);
        if (nextBtn) nextBtn.disabled = (idx === slideOrder.length-1 && shown >= reveals);
        const prog = document.querySelectorAll('.prog-fill');
        if (prog.length) {
          const pct = ((idx + (shown>0?0.5:0)) / slideOrder.length) * 100;
          prog.forEach(p => p.style.width = Math.min(100, pct)+'%');
        }
      }

      function render(syncHash) {
        slideOrder.forEach((id,i) => {
          const el = document.getElementById(id);
          if (el) el.classList.toggle('active', i === idx);
        });
        applyReveals(getSlideEl());
        localStorage.setItem(storageKey, idx);
        if (syncHash) history.replaceState(null, '', '#'+slideOrder[idx]);
        updateNav();
      }

      function revealNext() {
        const slideEl = getSlideEl();
        const reveals = slideEl.querySelectorAll('.reveal').length;
        const cnt = getRevealCount(slideEl.id);
        if (cnt < reveals) {
          setRevealCount(slideEl.id, cnt+1);
          applyReveals(slideEl);
          return true;
        }
        return false;
      }

      function hidePrev() {
        const slideEl = getSlideEl();
        const cnt = getRevealCount(slideEl.id);
        if (cnt > 0) {
          setRevealCount(slideEl.id, cnt-1);
          applyReveals(slideEl);
          return true;
        }
        return false;
      }

      window.go = function(d) {
        if (d > 0) { if (revealNext()) return; }
        else if (d < 0) { if (hidePrev()) return; }
        const nxt = idx + d;
        if (nxt >= 0 && nxt < slideOrder.length) {
          idx = nxt;
          render(true);
        }
      };

      window.addEventListener('hashchange', () => {
        const id = window.location.hash.slice(1);
        const newIdx = slideOrder.indexOf(id);
        if (newIdx >= 0 && newIdx !== idx) { idx = newIdx; render(false); }
      });

      document.addEventListener('keydown', e => {
        if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
        if (e.key === 'ArrowRight' || e.key === ' ' || e.key === 'Enter') { e.preventDefault(); go(1); }
        if (e.key === 'ArrowLeft' || e.key === 'Backspace') { e.preventDefault(); go(-1); }
      });

      document.querySelectorAll('.body').forEach(b => {
        b.addEventListener('click', e => { if (!e.target.closest('button, a')) go(1); });
      });

      // touch swipe hint
      let touchX = 0;
      document.addEventListener('touchstart', e => { touchX = e.changedTouches[0].screenX; }, {passive: true});
      document.addEventListener('touchend', e => {
        const diff = e.changedTouches[0].screenX - touchX;
        if (Math.abs(diff) > 40) { go(diff > 0 ? -1 : 1); }
      });

      render(!window.location.hash);
    })();
  </script>
</body>
